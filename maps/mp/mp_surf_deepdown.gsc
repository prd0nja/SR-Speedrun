#include maps\mp\gametypes\_hud_util;
#include common_scripts\utility;

main()
{
	sr\api\_map::swapTargetname("trigger_endmap", "endmap_trig");
	sr\api\_speedrun::createNormalWays("Normal Way;");
	// FX ++
	level._effect[ "fx_dotz_deepdown" ]			= loadfx( "fx_dotz_deepdown" );

	level.bubble_FX 							= loadFx( "follow_bubbles" );
	level.bubble_FX_fast						= loadFx( "follow_bubbles_fast" );
	level.fish_surround							= loadFx( "fish_surround_runner" );

	level.map_creator							= loadFx( "map_creator" );

	level.line_follow_geo						= loadFx( "follow_line_geo" );
	level.line_follow_geo_black					= loadFx( "follow_line_geo_black" );
	level.line_follow_geo_green					= loadFx( "follow_line_geo_green" );
	level.line_follow_geo_pink					= loadFx( "follow_line_geo_pink" );
	level.line_follow_geo_yellow				= loadFx( "follow_line_geo_yellow" );

	level.follow_line_geo_placement_teal		= loadFx( "follow_line_geo_placement_teal" );
	level.follow_line_geo_placement_green		= loadFx( "follow_line_geo_placement_green" );
	level.follow_line_geo_placement_pink		= loadFx( "follow_line_geo_placement_pink" );
	level.follow_line_geo_placement_yellow		= loadFx( "follow_line_geo_placement_yellow" );

	// DEBUG ++
	level.dbg_text = false;
	level.shark_dbg = false;

	// VARS ++
	level.step01 = false;
	level.step02 = false;
	level.creatorname = "#xoxo^2r4d";

	// PRECACHE ++
	preCacheModel ( "tag_origin" );
	preCacheModel ( "fullbody_tigershark" );
	preCacheModel ( "mapcreator" );
	//PrecacheMpAnim("shark_swim_f"); // FML .. the shark could have been so much better ...

	// LEVEL SETUP ++
	setExpFog( 2000, 20000, 0.4, 0.45, 0.7, 0.5 );
	ambientPlay( "ambient" );

	thread door01();
	thread door02();
	thread door03();
	thread door04();
	thread door05();
	thread door06();
	thread door07();

	thread playDots();
	thread spinners();

	thread shark_init();
	thread ending_teleporter();
	thread spawn_tp();
	thread secret_trig01();
	thread trail_teal();
	thread trail_yellow();
	thread trail_green();
	thread trail_pink();
	thread stg03_sound();

	ent_booster = getEntArray( "booster_st1_01", "targetname" );
		for( i = 0; i < ent_booster.size; i++ )
			ent_booster[i] thread booster_stage_1();

	ent_transition = getEntArray( "trans_white_trig", "targetname" );
		for( i = 0; i < ent_transition.size; i++ )
			ent_transition[i] thread transTrigs();

	ent_shark = getEntArray( "shark_spawner", "targetname" );
		for( i = 0; i < ent_shark.size; i++ )
			ent_shark[i] thread spawnShark();

	 // SPAWN ++
 		thread watchSpawn();

	// SURF+ //
	  level.surfDifficulty = "easy";
	  //level.surfNoTimer 	 = false;

}

// *********************************************************************************************************************************
//														Shark Setup
// *********************************************************************************************************************************

triggerOff()
{
	if ( !isdefined( self.realOrigin ) )
		self.realOrigin = self.origin;

	if ( self.origin == self.realorigin )
		self.origin += ( 0, 0, -10000 );
}

triggerOn()
{
	if ( isDefined( self.realOrigin ) )
		self.origin = self.realOrigin;
}

shark_idleMove()
{
	self endon( "shark_reset" );

	while( 1 )
	{
		wait 0.05;

		if( self.idleMove )
		{
			if( level.shark_dbg )
				IPrintLn( "Shark Idle" );

			orgPos = ( self.origin[0], self.origin[1], self.origin[2] );
			posUpper = ( self.origin[0], self.origin[1], ( self.origin[2] + self.idleZRadius ) );

			time = 2;
			accelDecelSpeed = ( time / 2 );

			self MoveTo( posUpper, time, accelDecelSpeed, accelDecelSpeed );
			wait time;

			self MoveTo( orgPos, time, accelDecelSpeed, accelDecelSpeed );
			wait time;
		}
	}
}

shark_init()
{
	shark_t = getent( "shark_trig", "targetname" );
	shark_m = getent( "shark_model", "targetname" );

	// ++ Settings
	shark_m.distMin = 300;
	shark_m.distMax = 2048;
	shark_m.lastMoveRadius = 150;
	shark_m.idleZRadius = 15;

	shark_m.following = false;
	shark_m.pSpeed = 0;
	shark_m.anglesToP = ( 0, 0, 0 );
	shark_m.distCurr = 0;
	shark_m.idleMove = false;
	shark_m.pTarget = undefined;

 	// shark pos // -19068 -15872 -972
	shark_start_pos = shark_m.origin;
	shark_start_ang = shark_m.angles;

	while( 1 )
	{
		wait 0.05;

		shark_t waittill( "trigger", player );
		shark_t triggerOff();

		tag = spawn(  "script_model", player.origin + ( 70, -70, 50 ) );
		tag.angles = ( 0, 90, 0 );
		tag setModel( "tag_origin" );
		tag linkto( player );

		shark_m.pTarget = tag;
		shark_m thread shark_idleMove();

		while( 1 )
		{
			wait 0.05;
			if( isDefined( player ) )
			{
				if( !shark_m.following )
				{
					shark_m.following = true;
					wait 0.05;
				}

				shark_m.distCurr = Distance( shark_m.origin, shark_m.pTarget.origin );

				shark_m.pSpeed = player surf\_util::getPlayerSpeed();
				shark_m.anglesToP = VectorToAngles( ( player.origin + ( 0, 0, 40 ) ) - shark_m.origin);

				if( shark_m.distCurr >= 20 )
					shark_m RotateTo( shark_m.anglesToP, 0.5 );

				// **************************************
				// Stop Movement || Teleport
				// Shark is below distMin & above distMax

				if( shark_m.distCurr < shark_m.distMin || shark_m.distCurr > shark_m.distMax )
				{
					if( shark_m.distCurr < shark_m.distMin )
					{
						shark_m.idleMove = true;
						continue;
					}

					shark_m.idleMove = false;

					if( shark_m.distCurr > shark_m.distMax )
					{
						if( level.shark_dbg )
							IPrintLn( "Shark Dist Greater Max" );

						shark_m.origin = shark_m.pTarget.origin;
					}
				}

				// **********************************
				// General Movement
				// Shark is between distMin & distMax

				else
				{
					shark_m.idleMove = false;

					// ************
					// Player Moves

					if( shark_m.pSpeed != 0 )
					{
						if( shark_m.distCurr < 1000 )
						{
							time = shark_m.distCurr / shark_m.pSpeed;
							shark_m MoveTo( shark_m.pTarget.origin, time );
						}

						else if( shark_m.distCurr >= 1000 )
						{
							time = shark_m.distCurr / ( shark_m.pSpeed * 1.2 );
							shark_m MoveTo( shark_m.pTarget.origin, time );
						}
					}

					// *****************
					// Player Not Moving

					else
					{
						time = distance( shark_m.origin, shark_m.pTarget.origin ) / 100;
						decAccTime = 1;

						if( time < decAccTime )
							decAccTime = time;

						if( level.shark_dbg )
							IPrintLn( "Speed 0 Shark In Range" );

						shark_m MoveTo( shark_m.pTarget.origin, time );

						if( shark_m.distCurr < shark_m.distMin )
						{
							if( level.shark_dbg )
								IPrintLn( "Triggered DECELL!" );

							shark_m MoveTo( shark_m.pTarget.origin, time, 0, decAccTime );
						}
					}
				}
			}

			// ***********
			// Reset Shark

			else
			{
				shark_m notify( "shark_reset" );

				shark_m.origin = shark_start_pos;
				shark_m.angles = shark_start_ang;

				shark_m.following = false;
				shark_m.pSpeed = 0;
				shark_m.anglesToP = ( 0, 0, 0 );
				shark_m.distCurr = 0;
				shark_m.idleMove = false;
				shark_m.pTarget = undefined;

				if( isdefined( tag ) )
				{
					tag Unlink();
					tag Delete();
				}

				shark_t triggerOn();

				wait 0.05;
				break;
			}
		}
	}
}

// *********************************************************************************************************************************
//														Spawn Setup
// *********************************************************************************************************************************

watchSpawn()
{
	while(1)
	{
		level waittill( "player_spawn", player );

		player.tag = spawn(  "script_model", player.origin + ( 0, 0, 50 ) );
		player.tag.angles = ( 0, 90, 0 );
		player.tag   setModel( "tag_origin" );
		player.tag   linkto( player );

		player thread bubbleFX();
		player thread fish_runner();

		/////////////////////
		// STAGE DEBUG SPAWNS
		//player thread stage_dbg();

		player setClientDvars( "r_filmusetweaks", 1 );
		player setClientDvars( "r_filmtweakenable", 1 );
		player setClientDvars( "r_filmtweaklighttint", "1 1 1" );
		player setClientDvars( "r_filmtweakdarktint", "0.8 0.9 1.4" );
		player setClientDvars( "r_filmtweakcontrast", 1 );
		player setClientDvars( "r_filmtweakdesaturation", 0 );
		player setClientDvars( "r_specularcolorscale", 10 );
		player setClientDvars( "r_blur", 0.7 );
		player setClientDvars( "r_dof_enable", 1 );
		player setClientDvars( "r_dof_tweak", 1 );
		player setClientDvars( "r_dof_viewmodelend", 12 );
		player setClientDvars( "r_dof_farblur", 1.5 );
		player setClientDvars( "r_dof_farstart", 2000 );
		player setClientDvars( "r_dof_farend", 20000 );
		player setClientDvars( "r_dof_bias", 1 );
		player setClientDvars( "r_dof_nearBlur", 4 );
		player setClientDvars( "r_drawsun", 1 );
		player setClientDvars( "r_drawdecals", 1 );
		player setClientDvars( "r_lodbiasrigid", -1000 );

		currentname = player.name;

		if( currentname == level.creatorname )
		{
			player attach( "mapcreator", "j_spine4" );

			if( isdefined( player.tag ) )
			{
				wait 1;

				PlayFXOnTag( level.line_follow_geo_black, player.tag, "tag_origin" );

				player IPrintLnBold( "Welcome XOXO!" );
				player thread map_creator_fx();
			}
		}
	}

	wait 0.05;
}

map_creator_fx()
{
	self endon( "death" );
	self endon( "disconnect" );
	self endon( "spawned" );

	while(1)
	{
		if( isdefined( self ) )
		{
			currSpeed = self surf\_util::getPlayerSpeed();
			if( currSpeed <= 200 )
			{
				PlayFX( level.map_creator, self.origin );
				wait 0.1;
			}
			wait 0.2;
		}

		else
			break;
	}
}

// *********************************************************************************************************************************
//														Stage Debug
// *********************************************************************************************************************************

stage_dbg()
{
	stg2_dbg = getent( "stage_2_dbg", "targetname" );
	stg3_dbg = getent( "stage_3_dbg", "targetname" );

	self IPrintLn( "Please move; 3" );
	wait 0.5;

	self IPrintLn( "Please move; 2" );
	wait 0.5;

	self IPrintLn( "Please move; 1" );
	wait 0.5;

	self SetOrigin( stg3_dbg.origin );

	self surf\_util::setPlayerSpeed( 2400 );
}

// *********************************************************************************************************************************
//														Map Setup
// *********************************************************************************************************************************

secret_trig01()
{
	thread secret_trig02();

	secret01_t = getent( "secret01_trig", "targetname" );

	secret01_t waittill( "trigger", player );

	player thread secret_door();

	level.step01 = true;
}

secret_trig02()
{
	secret02_t = getent( "secret02_trig", "targetname" );

	secret02_t waittill( "trigger", player );

	level.step02 = true;
}

secret_door()
{
	door = getent( "secret_door", "targetname" );
	sec_tp = getent( "end_tp_secret", "targetname" );

	while( 1 )
	{
		if( level.step01 && level.step02 )
		{
			if( isdefined( self ) )
			{
				self SetOrigin( sec_tp.origin );
				self SetPlayerAngles( sec_tp.angles );
				self SetVelocity( ( 0, 0, 0 ) );
			}

			else
				IPrintLnBold( "Could you pet the shark please?" );

			door MoveZ( 250, 3, 1, 0.5 );
			wait 2;

			break;
		}
		wait 1;
	}
}

spawnShark()
{
	spawnPoint = self.origin;

	if( isdefined( self.target ) )
		shark_radius = int( self.target );
	else
		shark_radius = 2000;

	shark = spawn(  "script_model", spawnPoint );
	shark   setModel( "fullbody_tigershark" );

	shark.angles = self.angles;

	while(1)
	{
		randomX = RandomIntRange( Int( spawnPoint[0] - shark_radius ), Int( spawnPoint[0] + shark_radius ) );
		randomY = RandomIntRange( Int( spawnPoint[1] - shark_radius ), Int( spawnPoint[1] + shark_radius ) );
		staticZ = spawnPoint[2];

		finPos = ( randomX, randomY, staticZ );
		finAngles = VectorToAngles( finPos - spawnPoint );

		time = ( Distance2D( spawnPoint, finPos ) / 45 );

		if( time < 4 )
			time = 4;

		shark RotateTo( finAngles, 2, 1, 1 );
		shark MoveTo( finPos, time, 1, 1 );

		shark waittill("movedone");

		finAngles = VectorToAngles( spawnPoint - finPos );
		finPos = spawnPoint;

		shark RotateTo( finAngles, 2, 1, 1 );
		shark MoveTo( finPos, time, 1, 1 );

		shark waittill("movedone");
	}
}

stg03_sound()
{
	sound_t = getent( "stg03_sound_trig", "targetname" );

	while( 1 )
	{
		sound_t waittill( "trigger", player );

		player PlaySoundToPlayer( "stg3_fx", player );

		wait 1;
	}
}

////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////// Booster Setup //////////////////////////////////////

booster_stage_1()
{
	if( isdefined( self.target ) )
		vel_boost = int( self.target );
	else
		vel_boost = 2000;

	while( 1 )
	{
		self waittill( "trigger", user );

		if( !isdefined( user.boost_cooldown ) )
			user.boost_cooldown = false;

		currSpeed = user surf\_util::getPlayerSpeed();

		if( currSpeed <= vel_boost && !user.boost_cooldown )
		{
			if( level.dbg_text )
			{
				user IPrintLn( "Custom Speed @ " +vel_boost );
				user IPrintLn( "Below Speed" );
			}

			user surf\_util::setPlayerSpeed( vel_boost );
			//user setPlayerSpeed_withZ( vel_boost );
			user thread boost_cooldown( 0.25 );
		}

		else if( currSpeed >= vel_boost && level.dbg_text )
				user IPrintLn( "Above Speed" );

		else if( level.dbg_text )
			user IPrintLn("Cooldown!");

		wait 0.05;
	}
}

boost_cooldown( time )
{
	if( isdefined( self.boost_cooldown ) && isdefined( self ) )
	{
		self.boost_cooldown = true;
		wait time;

		if( isdefined( self ) )
			self.boost_cooldown = false;
	}
}

