////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////// Stage Transition Setup /////////////////////////////////

transTrigs()
{
	while(1)
	{
		self waittill( "trigger", player );

		if( !isDefined( player.inTransition ) )
			player.inTransition = false;

		if( isDefined( player.inTransition ) && player.inTransition )
		{
			wait 0.05;
			continue;
		}

		player.inTransition = true;
		player thread whiteShader();
	}
}

whiteShader()
{
	self.trans_white 			= newClientHudElem( self );
	self.trans_white.x 			= 0;
	self.trans_white.y 			= 0;
	self.trans_white.alignX 	= "left";
	self.trans_white.alignY 	= "top";
	self.trans_white.horzAlign 	= "fullscreen";
	self.trans_white.vertAlign 	= "fullscreen";
	self.trans_white.alpha 		= 0;
	self.trans_white 			setshader("white", 640, 480);

	wait 0.05;
	if( isDefined( self ) )
	{
		self PlaySoundToPlayer( "riser", self );

		self.trans_white fadeOverTime( 0.15 );
		self.trans_white.alpha = 1;

		wait 0.5;

		if( isDefined( self ) )
		{
		 	self.trans_white fadeOverTime( 0.2 );
			self.trans_white.alpha = 0;

			wait 0.2;

			if( isDefined( self ) && isDefined( self.trans_white ) )
				self.trans_white destroy();

			self thread whiteShader_timeout( 2 );
		}
	}
}

whiteShader_timeout( time )
{
	if( !isDefined( time ) )
		time = 2;

	wait time;

	if( isDefined( self ) )
		self.inTransition = false;
}

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////// Teleporter Setup /////////////////////////////////////

spawn_tp()
{
	spawn_tp_org = getent( "spawn_tp", "targetname" );
	spawn_tp_trig = getent( "spawn_tp_trig", "targetname" );

	while( 1 )
	{
		spawn_tp_trig waittill( "trigger", player );

		player SetOrigin( spawn_tp_org.origin );
		player SetPlayerAngles( spawn_tp_org.angles );
		player SetVelocity( ( 0, 0, 0 ) );

		wait 0.05;
	}
}

ending_teleporter()
{
	end_t = getent( "end_tele_trig", "targetname" );
	end_telespot = getent( "end_tp", "targetname" );

	while( 1 )
	{
		end_t waittill( "trigger", player );

		player SetOrigin( end_telespot.origin );
		player SetPlayerAngles( end_telespot.angles );
		player SetVelocity( ( 0, 0, 0 ) );

		wait 0.05;
	}
}

////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////// Brushmodel Setup /////////////////////////////////////

door01()
{
	doorL1 = getent( "door_l1", "targetname" );
	doorR1 = getent( "door_r1", "targetname" );

	dL1_start = doorL1.origin;
	dR1_start = doorR1.origin;

	while( 1 )
	{
		doorL1 MoveY( -2016, 1, 0.5, 0.5 );		doorR1 MoveY(  2016, 1, 0.5, 0.5 );
		wait 1;

		doorL1 MoveTo( dL1_start, 1, 0.5, 0.5 );	doorR1 MoveTo( dR1_start, 1, 0.5, 0.5 );
		wait 1;
	}
}

