fish_runner()
{
	self endon( "death" );
	self endon( "disconnect" );
	self endon( "spawned" );

	while(1)
	{
		if( isdefined( self ) )
		{
			currSpeed = self surf\_util::getPlayerSpeed();
			if( currSpeed <= 1200 )
			{
				PlayFX( level.fish_surround, self.origin );
				wait 2;
			}

			wait 1;
		}

		else
			break;
	}
}

bubbleFX()
{
	self endon( "death" );
	self endon( "disconnect" );
	self endon( "spawned" );

	tag = spawn(  "script_model", self.origin + ( 0, 0, 50 ) );
	tag.angles = ( 0, 90, 0 );
	tag setModel( "tag_origin" );
	tag linkto( self );

	wait 1;

	while(1)
	{
		if( !isdefined( self ) )
		{
			if( isdefined( tag ) ) tag delete();
			break;
		}

		currentspeed = self surf\_util::getPlayerSpeed();
		if ( currentspeed <= 300 )
		{
			PlayFX( level.bubble_FX, self.origin + ( 0, 0, 50 ) );
			wait 0.2;
		}

		wait 0.2;
	}
}

