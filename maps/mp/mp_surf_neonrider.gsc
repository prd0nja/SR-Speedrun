secret1()
{
	self endon( "spawned" );
	self endon( "disconnect" );

	radio1_trig = getent( "portal_radio_trig", "targetname" );
		  radio = getent( "portal_radio", "targetname" );

	radio1_trig waittill( "trigger", player );

    	player.secret1 = 1;
	  	player thread secret2();

    	radio  playSound("radio2");
      	  wait 22;
}

secret2()
{
	self endon("disconnect");

	cube_trig = getent( "portal_cube_trig", "targetname" );
		 cube = getent( "portal_cube", "targetname" );

	cube_trig waittill( "trigger", player );

	    player thread secret3();

    	cube playSound( "cube" );
    	  wait 6;
}

secret3()
{
	self endon( "disconnect" );

	glados_enter = getent( "portal_glados_enter","targetname" );
		  glados = getent( "portal_glados_lower","targetname" );

    glados_enter waittill( "trigger", player );

		player thread secret4();

    	glados playSound( "youfoundme" );
    	  wait 5;
}

secret4()
{
	self endon( "disconnect" );

	glados_trig = getent( "portal_glados_trig_use","targetname" );
	    glados2 = getent( "portal_glados_lowest","targetname" );

    glados_trig waittill( "trigger", player );

		player thread cakeSound();
		player thread setupPortalgun();

    	glados2 playSound( "goodjob" );
    	  wait 5;
}

// ###########################################################################################################################################################
// ###########################################################################################################################################################
// ###########################################################################################################################################################

cakeSound()
{
	self endon( "disconnect" );

	cake_trigger = getent( "trig_cake", "targetname" );

	cake_trigger waittill( "trigger" , player );

	if( !isDefined( player.cakesound )) player.cakesound = 0;
	if( !isDefined( player.finished_secret )) player.finished_secret = 0;
	if( player.finished_secret == 0 && player.cakesound == 0 )
	{
		player playSound( "cake" );
		player.cakesound = 1;
	}

}

setupPortalgun()
{
	self endon( "disconnect" );

	spawn_trig = getent( "spawn_portalgun", "targetname" );

	if( !isDefined( self.finished_secret )) self.finished_secret = 0;
    if( self.finished_secret == 0 )
    {
    	spawn_trig waittill( "trigger", player );

    	player giveWeapon 		( "portalgun" );
		player switchToWeapon 	( "portalgun" );
		player setModel 		( "model_chell2" );

		if( player hasWeapon( "portalgun" )) player setWeaponAmmoClip( "portalgun", 11 );

		player thread portalfx_light();
		player thread watchPortalgun();

    	player.finished_secret = 1;
    	player.finished_secret_but_respawned = 0;
	}

	if( self.finished_secret == 1 && self.finished_secret_but_respawned == 1 )
    {
    	self giveWeapon 	( "portalgun" );
    	self setModel 		( "model_chell2" );
		self iPrintLnBold 	( "^5Portalgun ^7was put into your ^2inventory^7!" );

		if( self hasWeapon( "portalgun" )) self setWeaponAmmoClip( "portalgun", 11 );

		if( !isDefined( self.cooldown )) self.cooldown = 0;
		if( !isDefined( self.shots ))    self.shots = 0;

		self thread portalfx_light();
		self thread watchPortalgun();

		if( self.cooldown == 1 ) self setWeaponAmmoClip( "portalgun", 0 );
	}
}

watchPortalgun()
{
	self endon( "disconnect" );
	self endon( "spawned" );
	self endon( "death" );

	weap = "portalgun";

	if( !isDefined( self.cooldown )) self.cooldown = 0;
	if( !isDefined( self.shots ))    self.shots = 0;

    while(1)
    {
    	if( isDefined( self ))
    	{
    		while ( self.shots < 10 )
    		{
	    		self waittill ( "weapon_fired" );
		        if( self getCurrentWeapon() == weap )
				{
					  wait 0.1;

					if( isDefined( self.dummy )) self.dummy delete();
		        	self.dummy = spawn( "script_origin", self.origin );
					self.dummy   playSound( "lol" );

					end = self vectorScale( anglesToForward( self getPlayerAngles() ), 100000 );
					eye = self getTagOrigin( "tag_eye" );

					 portal = spawn(  "script_model", eye );
					   portal setModel( "portal_red" );
					portal2 = spawn(  "script_model", eye );
					  portal2 setModel( "portal_red" );
					 turret = spawn(  "script_model", eye - ( 0, 0, 25 ) );
					   turret setModel( "turret" );

					 portal.angles = self getPlayerAngles();
					portal2.angles = self getPlayerAngles() + ( 180, 0, 0 );
					 turret.angles = self getPlayerAngles();

						self thread portalfx_beacon( portal );

					 portal moveTo( end, 200 );
					portal2 moveTo( end, 200 );
					 turret moveTo( end, 200 );

						self thread killEnt( portal, portal2, turret, 15 );

					self.shots++;
					wait 0.1;

				}
			}

			if( self.shots >= 10 && self.cooldown == 0 )
			{
				self.cooldown = 1;
				self thread portalCooldown( weap );
			}
		}
		wait 0.1;
	}
}

portalCooldown( weap )
{
	self endon( "disconnect" );

	self setWeaponAmmoClip( weap, 0 );
	self iPrintLnBold( "10 shots reached" );
	self thread progressBar( 15, "15s Cooldown" );
	  wait 15;

	self setWeaponAmmoClip( weap, 11 );
	self.cooldown = 0;
	self.shots = 0;
}

portalfx_beacon( portal )
{
	for( i=0; i<99; i++ )
	{
		if( isDefined( portal ) ) playFxOnTag( level.portalbeacon, portal, "tag_origin" );
		  wait 0.15; // spawns fx on "portal" for 14.85 seconds
	}
}

killEnt( ent1, ent2, ent3, time )
{
        wait time;
        ent1 delete();
        ent2 delete();
        ent3 delete();
}

progressBar( duration, text )
{
	self endon( "disconnect" );

        useBar     = createPrimaryProgressBar();
        useBarText = createPrimaryProgressBarText();
        useBarText   setText( text );
        useBar       updateBar( 0, 1 / duration );

        for  ( waitedTime = 0; waitedTime < duration; waitedTime += 0.05 )
       	wait ( 0.05 );

        useBar     destroyElem();
        useBarText destroyElem();
}

portalfx_light()
{
	self endon( "model_dead" );

	tag = spawn(  "script_model", self.origin + (0,100,100) );
	tag   setModel( "tag_origin" );
	tag   linkto( self );

	tag2 = spawn(  "script_model", self.origin + (0,-100,100) );
	tag2   setModel( "tag_origin" );
	tag2   linkto( self );

	self thread onSpawned( tag, tag2 );
	self thread onDeath( tag, tag2 );
	self thread onDisconnect( tag, tag2 );

	wait 1; // fml ..... lol

	playFXOnTag( level.portallight2, tag, "tag_origin" );
	playFXOnTag( level.portallight2, tag2, "tag_origin" );
}

onSpawned( model1, model2, model3 )
{
	self waittill( "spawned" );
	if( isdefined( model1 ) ) model1 delete();
	if( isdefined( model2 ) ) model2 delete();
	if( isdefined( model3 ) ) model3 delete();
	self notify( "model_dead" );
}

onDeath( model1, model2, model3 )
{
	self waittill( "death" );
	if( isdefined( model1 ) ) model1 delete();
	if( isdefined( model2 ) ) model2 delete();
	if( isdefined( model3 ) ) model3 delete();
	self notify( "model_dead" );
}

onDisconnect( model1, model2, model3 )
{
	self waittill( "disconnect" );
	if( isdefined( model1 ) ) model1 delete();
	if( isdefined( model2 ) ) model2 delete();
	if( isdefined( model3 ) ) model3 delete();
	self notify( "model_dead" );
}

