#include maps\mp\gametypes\_hud_util;
#include common_scripts\utility;

main()
{
	sr\api\_map::swapTargetname("trigger_endmap", "endmap_trig");
	sr\api\_speedrun::createNormalWays("Normal Way;");
	level._effect[ "fx_dotz" ]			= loadfx( "fx_dotz" );
	level._effect[ "fx_dotz_stage2" ]	= loadfx( "fx_dotz_stage2" );
	level._effect[ "fx_dotz_stage3" ]	= loadfx( "fx_dotz_stage3" );
	level._effect[ "fx_dotz_stage4" ]	= loadfx( "fx_dotz_stage4" );
	level._effect[ "fx_dotz_stage4_2" ]	= loadfx( "fx_dotz_stage4_2" );

	level._effect[ "surfstart_test" ]	= loadfx( "surfstart_test" );
	level._effect[ "surfstart_test_back" ]	= loadfx( "surfstart_test_back" );
	level._effect[ "surfstart_test_side" ]	= loadfx( "surfstart_test_side" );

	level.particlefollow 	= loadfx( "follow_sparks" );
	level.portallight2 		= loadFx( "portalgun_fx_looplight" );
	level.portalbeacon  	= loadFx( "portalgun_fx_beacon2" );
	level.candle 			= loadfx( "candle" );

	// THREADS+ //
	 // level Stuff
	    thread transTrigSetup();
		thread rotateGlados();
		thread radioFinish();
		thread playDots();
		thread cakeFX();

	 // player Stuff
 		thread watchSpawn();

	// PRECACHE+ //
	  PreCacheItem  ( "portalgun" );

	  preCacheModel ( "portal_companion_cube" );
	  PreCacheModel ( "model_chell2" );
	  preCacheModel ( "v_portalgun" );
	  preCacheModel ( "w_portalgun" );
	  preCacheModel ( "portal_red" );
	  preCacheModel ( "tag_origin" );
	  preCacheModel ( "mapcreator" );
	  preCacheModel ( "turret" );

	// MISC+ //
	  ambientPlay( "ambient" );

	// SURF+ //
	  //level.surfDifficulty = "intermediate";
	  //level.surfNoTimer 	 = true;

}

watchSpawn()
{
	while(1)
	{
		level waittill( "player_spawn", player );

		// ######################################
		player setClientDvars( "r_dlightlimit", 4 ); // designed for 2 portalguns or better said 2 dynamic lights per player; lights could flicker or just not show if there are more than 2 portalguns

		if( !isDefined( player.isInMapCreator ) ) player.isInMapCreator = 0;
		if( player.isInMapCreator == 0 ) player thread mapCreator();

		if( !isDefined( player.hasMapCreator ) ) player.hasMapCreator = 0;
		if( player.hasMapCreator == 1 ) player attach("mapcreator", "j_spine4");

		if( !isDefined( player.secret1 ) ) player.secret1 = 0;
		if( player.secret1 == 0 )
		{
			player thread secret1();
		}

		if( !isDefined( player.finished_secret ) ) player.finished_secret = 0;
		if( player.finished_secret == 1 )
		{
			player.finished_secret_but_respawned = 1;
			player thread setupPortalgun();
		}
	}
	wait 0.05;
}

mapCreator()
{
	self endon( "disconnect" );
	self endon( "creatorAttached" );

	self.isInMapCreator = 1;

	currentname = self.name;
	creatorname = "xoxo^2r4d0xzz";

	developer = getent( "trigger_dev", "targetname" );
	developer waittill( "trigger", user );

	if( currentname == creatorname )
	{
		self attach("mapcreator", "j_spine4");
		self.hasMapCreator = 1;

		self notify( "creatorAttached" );
	}
}

rotateGlados()
{
	glados_base = getent( "portal_glados_up_spin", "targetname" );
	while(1)
	{
			glados_base rotateYaw( 360, 10 );
			  wait ( 9.9 );
	}
}

cakeFX()
{
	cakecandle = getent( "cake", "targetname" );
	candlefire = spawnFX ( level.candle, cakecandle.origin + ( 0, 0, 10 ) );
	  wait 5;

	triggerFX( candlefire, 2 );

}

radioFinish()
{
	end_radio = getent( "secret_radio", "targetname" );
		end_radio playLoopSound( "radio" );
}

