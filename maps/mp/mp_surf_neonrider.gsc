// ###########################################################################################################################################################
// ###########################################################################################################################################################
// ###########################################################################################################################################################

transTrigSetup()
{
	ent_transition = getEntArray( "transition", "targetname" );
	for( i = 0; i < ent_transition.size; i++ )
		ent_transition[i] thread transTrigs();
}

transTrigs()
{
	while(1)
	{
		self waittill( "trigger", player );

		// ##############################################
		currentspeed = player surf\_util::getPlayerSpeed();
		if ( currentspeed != 0 && currentspeed >= 1 && !player isOnGround() ||  currentspeed != 0 && currentspeed >= 1 && player jumpButtonPressed() )
		{
			player playlocalsound( "speed" );

			  player.trans_white 			= newClientHudElem( player );
			  player.trans_white.x 			= 0;
			  player.trans_white.y 			= 0;
			  player.trans_white.alignX 	= "left";
			  player.trans_white.alignY 	= "top";
			  player.trans_white.horzAlign 	= "fullscreen";
			  player.trans_white.vertAlign 	= "fullscreen";
			  player.trans_white.alpha 		= 0;
			  player.trans_white 			setshader("white", 640, 480);

			wait 0.05;
		  if( !isDefined( player ) ) continue;	// if player disconnects during code execution, restart loop
			player surf\_util::setPlayerSpeed( 1500 );
			  player.trans_white fadeOverTime( 0.15 );
			  player.trans_white.alpha = 1;

			wait 0.5;
		  if( !isDefined( player ) ) continue;  // if player disconnects during code execution, restart loop
			  player.trans_white fadeOverTime( 0.2 );
			  player.trans_white.alpha = 0;

			if( !isDefined( player.msg_nextstage ) ) player.msg_nextstage = 0;
			if( player.msg_nextstage == 0 ) player thread nextStage();

			wait 1;
		  if( !isDefined( player ) ) continue;  // if player disconnects during code execution, restart loop
			  player.trans_white destroy();
		}

		else
		{
			if( !isDefined( player.pushed ) ) player.pushed = 0;
			player.pushed = 0;
		}

		if( !isDefined( player.pushed ) ) player.pushed = 0;
		if( player.pushed == 0 )
		{
			player.m 		= vectorDot( anglesToForward( (0, player getPlayerAngles() [1], 0) ), vectorNormalize( player getVelocity() ) ) + .01;
			player.dir 		= 1;
			player.movmnt 	= 1;

			 if( player.m < 0 )
			 {
				 player.dir 	= -1;
				 player.movmnt  = -1;
			 }

			player.vel = player getVelocity();
			if( isDefined( player.vel ) && ( player.dir ) )
			{
				w = vectorScale( anglesToForward(( 0, player getPlayerAngles() [1], 0)), length(( player.vel[0], player.vel[1], 0)) );
				player setVelocity( ( w[0] * player.dir + player.movmnt, w[1] * player.dir + player.movmnt, player.vel[2] + 200) );
				player.pushed = 1;
			}
		  	wait 0.05;
		}
	}
}

nextStage()
{
	self endon( "disconnect" );
	if( self.msg_nextstage == 0 )
	{
		self.msg_nextstage = 1;
		 self thread myMessage( "Next Stage!" );
		  wait 5;
	  	self.msg_nextstage = 0;
	}
}

myMessage( hintText )
{
	notifyData = spawnstruct();
	notifyData.notifyText = hintText;
	notifyData.glowColor = ( 0.5, 0.0, 0.8 );
	self thread maps\mp\gametypes\_hud_message::notifyMessage( notifyData );
}

playDots()
{
	// dotz in map: 01-27 /////////////////
	dotz02 = getent( "dotz02", "targetname" );
	dotz08 = getent( "dotz08", "targetname" );
	dotz16 = getent( "dotz16", "targetname" );
	dotz23 = getent( "dotz23", "targetname" );
	dotz25 = getent( "dotz25", "targetname" );
	///////////////////////////////////////

	    ent = maps\mp\_utility::createOneshotEffect( "fx_dotz" );
     	ent.v[ "origin" ] 	= ( dotz02.origin );
     	ent.v[ "angles" ] 	= ( 270, 0, 0 );
     	ent.v[ "fxid" ] 	= "fx_dotz";
     	ent.v[ "delay" ] 	= -15;

     	ent = maps\mp\_utility::createOneshotEffect( "fx_dotz_stage2" );
     	ent.v[ "origin" ]	= ( dotz08.origin );
     	ent.v[ "angles" ]	= ( 270, 0, 0 );
     	ent.v[ "fxid" ] 	= "fx_dotz_stage2";
     	ent.v[ "delay" ] 	= -15;

      	ent = maps\mp\_utility::createOneshotEffect( "fx_dotz_stage3" );
     	ent.v[ "origin" ] 	= ( dotz16.origin );
     	ent.v[ "angles" ] 	= ( 270, 0, 0 );
     	ent.v[ "fxid" ] 	= "fx_dotz_stage3";
     	ent.v[ "delay" ] 	= -15;

       	ent = maps\mp\_utility::createOneshotEffect( "fx_dotz_stage4" );
     	ent.v[ "origin" ] 	= ( dotz23.origin );
     	ent.v[ "angles" ] 	= ( 270, 0, 0 );
     	ent.v[ "fxid" ] 	= "fx_dotz_stage4";
     	ent.v[ "delay" ] 	= -15;

        ent = maps\mp\_utility::createOneshotEffect( "fx_dotz_stage4_2" );
     	ent.v[ "origin" ] 	= ( dotz25.origin );
     	ent.v[ "angles" ] 	= ( 270, 0, 0 );
     	ent.v[ "fxid" ] 	= "fx_dotz_stage4_2";
     	ent.v[ "delay" ] 	= -15;

     	ent = maps\mp\_utility::createOneshotEffect( "surfstart_test" ); // 180,0,180 steht
     	ent.v[ "origin" ] 	= ( 255, 0, 16 );
     	ent.v[ "angles" ] 	= ( 180, 0, 180 );
     	ent.v[ "fxid" ] 	= "surfstart_test";
     	ent.v[ "delay" ] 	= -15;

     	ent = maps\mp\_utility::createOneshotEffect( "surfstart_test_side" );
     	ent.v[ "origin" ] 	= ( -208, 412, 16 );
     	ent.v[ "angles" ] 	= ( 0, -90, 0 );
     	ent.v[ "fxid" ] 	= "surfstart_test_side";
     	ent.v[ "delay" ] 	= -15;

